<Window x:Class="LocalSettingsSync.Views.OverwritePromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Already Exists"
        Width="580" SizeToContent="Height"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20" >
        <TextBlock Text="A file already exists at the destination:" Margin="0,0,0,6"/>
        <TextBlock x:Name="FilePathText" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Overwrite" Width="90" Margin="0,0,6,0" Click="OnOverwrite"/>
            <Button Content="Overwrite All" Width="100" Margin="0,0,16,0" Click="OnOverwriteAll"/>
            <Button Content="Skip" Width="90" Margin="0,0,6,0" Click="OnSkip"/>
            <Button Content="Skip All" Width="90" Margin="0,0,16,0" Click="OnSkipAll"/>
            <Button Content="Cancel" Width="90" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
