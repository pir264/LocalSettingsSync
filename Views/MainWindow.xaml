<Window x:Class="LocalSettingsSync.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalSettingsSync"
        MinWidth="700" MinHeight="550"
        Width="800" Height="650"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Action buttons -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="8,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Backup to Target"
                        Command="{Binding BackupCommand}"
                        Margin="0,0,8,0"
                        Width="130"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                <Button Content="Restore to Source"
                        Command="{Binding RestoreCommand}"
                        Width="130"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Source folder -->
                <GroupBox Header="Source Folder  (your .NET solution root)">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SourceFolder, Mode=OneWay}"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Padding="4,2"
                                 Margin="0,0,6,0"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Command="{Binding BrowseSourceCommand}"/>
                    </Grid>
                </GroupBox>

                <!-- Target folder -->
                <GroupBox Header="Target Folder  (backup destination)">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding TargetFolder, Mode=OneWay}"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Padding="4,2"
                                 Margin="0,0,6,0"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Command="{Binding BrowseTargetCommand}"/>
                    </Grid>
                </GroupBox>

                <!-- File filters -->
                <GroupBox Header="File Filters">
                    <StackPanel>
                        <TextBlock Text="Enter one pattern per line. Exact filenames or regex patterns. Lines starting with # are ignored."
                                   Foreground="Gray" FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <TextBox AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="100"
                                 Text="{Binding FilterPatternsText, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Padding="4"/>
                        <TextBlock Foreground="Gray" FontSize="11" Margin="0,3,0,0">
                            Examples: <Run FontFamily="Consolas" FontWeight="SemiBold">appsettings.local.json</Run>
                            &amp;nbsp;&amp;nbsp;or regex:&amp;nbsp;
                            <Run FontFamily="Consolas" FontWeight="SemiBold">.*\.local\.json$</Run>
                        </TextBlock>
                        <Button Content="Preview Matching Files"
                                Command="{Binding ScanCommand}"
                                HorizontalAlignment="Right"
                                Margin="0,6,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Preview -->
                <GroupBox>
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Preview — "/>
                            <TextBlock Text="{Binding PreviewFiles.Count}"/>
                            <TextBlock Text=" file(s) found"/>
                        </StackPanel>
                    </GroupBox.Header>
                    <Grid MinHeight="120">
                        <TextBlock Text="No files scanned yet. Set folders and filters, then click 'Preview Matching Files'."
                                   Foreground="Gray"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewFiles.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ListView ItemsSource="{Binding PreviewFiles}"
                                  MaxHeight="250"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.Style>
                                <Style TargetType="ListView">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewFiles.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.Style>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Relative Path" Width="420" DisplayMemberBinding="{Binding RelativePath}"/>
                                    <GridViewColumn Header="File Name" Width="220" DisplayMemberBinding="{Binding FileName}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
