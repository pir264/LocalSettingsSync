<Window x:Class="LocalSettingsSync.Views.ProfileNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile Name"
        Width="340" SizeToContent="Height"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16">
        <TextBlock Text="Enter a profile name:" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox" Padding="4,3" Margin="0,0,0,4"
                 KeyDown="OnKeyDown"/>
        <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="11"
                   Margin="0,0,0,8" Visibility="Collapsed"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Click="OnOk" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="OnCancel" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
